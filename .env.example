# Required — PostgreSQL connection URI for the WFO database.
# A bare postgresql:// scheme is auto-coerced to postgresql+psycopg:// (psycopg v3).
DATABASE_URI=postgresql+psycopg://user:pass@localhost/orchestrator

# URL of orchestrator-core's MCP server (serves the domain tools the agent calls).
WFO_CORE_MCP_URL=http://localhost:8080/mcp

# Public URL of this agent service (advertised in the A2A agent card).
BASE_URL=http://localhost:8080

# LLM model in provider:model format (see README for examples).
AGENT_MODEL=openai:gpt-4o
# AGENT_API_BASE=
# AGENT_API_KEY=
# AGENT_API_VERSION=

# Optional domain knowledge injected into the search prompt (identifier conventions and their
# filter fields). Empty disables the section. See README "Identifier-aware search".
# AGENT_DOMAIN_CONTEXT="Circuit codes look like IS#### and map to the imsCircuitId field — filter with like."

# Authentication (via oauth2_lib) — set OAUTH2_ACTIVE=false to disable.
OAUTH2_ACTIVE=false
# OAUTH2_OUTBOUND_ACTIVE=true
# OIDC_BASE_URL=https://idp.example.com
# OIDC_CONF_URL=https://idp.example.com/.well-known/openid-configuration
# OAUTH2_RESOURCE_SERVER_ID=
# OAUTH2_RESOURCE_SERVER_SECRET=
# OAUTH2_TOKEN_URL=https://idp.example.com/oauth2/token
