# Required — PostgreSQL connection URI for the WFO database
DATABASE_URI=postgresql://user:pass@localhost/orchestrator

# Public URL of the orchestrator-core API
ORCHESTRATOR_API_URL=http://localhost:8080

# Public URL of this agent service
BASE_URL=http://localhost:8080

# LLM model in provider:model format (see README for examples)
AGENT_MODEL=openai:gpt-4o
# AGENT_API_BASE=
# AGENT_API_KEY=
# AGENT_API_VERSION=

# Enable debug logging for agent execution
AGENT_DEBUG=false

# Authentication (via oauth2_lib) — set OAUTH2_ACTIVE=false to disable
OAUTH2_ACTIVE=false
# OIDC_BASE_URL=https://idp.example.com
# OIDC_CONF_URL=https://idp.example.com/.well-known/openid-configuration
# OAUTH2_RESOURCE_SERVER_ID=
# OAUTH2_RESOURCE_SERVER_SECRET=
# OAUTH2_TOKEN_URL=https://idp.example.com/oauth2/token
