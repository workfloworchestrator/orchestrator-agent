DATABASE_URI=postgresql://user:password@localhost:5432/orchestrator

# Public URL of this agent (used for A2A agent card)
BASE_URL=http://localhost:8080

# Orchestrator-core API URL (used for entity details and export links)
ORCHESTRATOR_API_URL=http://localhost:8080

# LLM settings (read by orchestrator.llm_settings)
AGENT_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-...

# Embedding model for semantic search (must match the model used for indexing)
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Auth (OIDC via oauth2_lib, same as orchestrator-core)
# When OAUTH2_ACTIVE=true:
#   - Incoming requests require a valid Bearer token (except /health and /.well-known/agent-card.json)
#   - Outgoing requests to orchestrator-core include a client credentials token
# OAUTH2_ACTIVE=true
# OAUTH2_AUTHORIZATION_ACTIVE=false
# OIDC_BASE_URL=http://localhost:8085
# OIDC_CONF_URL=http://localhost:8085/realms/orchestrator/.well-known/openid-configuration
# OAUTH2_RESOURCE_SERVER_ID=orchestrator-client
# OAUTH2_RESOURCE_SERVER_SECRET=
# OAUTH2_TOKEN_URL=http://localhost:8085/realms/orchestrator/protocol/openid-connect/token
