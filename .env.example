DATABASE_URI=postgresql://user:password@localhost:5432/orchestrator

# Public URL of this agent (used for export links, A2A agent card)
BASE_URL=http://localhost:8080

# LLM settings (read by orchestrator.llm_settings)
AGENT_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-...

# Embedding model for semantic search (must match the model used for indexing)
# EMBEDDING_MODEL=openai/text-embedding-3-small
