# Required — PostgreSQL connection URI for the WFO database
DATABASE_URI=postgresql://user:pass@localhost/orchestrator

# Public URL of the orchestrator-core API
ORCHESTRATOR_API_URL=http://localhost:8080

# URL of the orchestrator-core MCP server (used by workflow form-fill skill)
WFO_CORE_MCP_URL=http://localhost:8000/mcp/

# Domain agents (kagent). Leave empty to disable the corresponding skill.
# This is the bootstrap URL, we use it to fetch each agent's card from
# <URL>/.well-known/agent-card.json. The card itself advertises the canonical
# endpoint; for local-dev port-forwards we override it back to this base URL.
# Examples below are the in-cluster service DNS shape; adjust the namespace
# (here `kagent`) and service name to match each agent's deployment.
# IMS_AGENT_A2A_URL=http://ims-mcp-agent.kagent:8080/
# CIM_AGENT_A2A_URL=http://cim-mcp-agent.kagent:8080/
# JIRA_AGENT_A2A_URL=http://jira-mcp-agent.kagent:8080/
# TELEMETRY_AGENT_A2A_URL=http://telemetry-agent.kagent:8080/
# ALARMING_AGENT_A2A_URL=http://alarming-agent.kagent:8080/

# Public URL of this agent service
BASE_URL=http://localhost:8080

# LLM model in provider:model format (see README for examples)
AGENT_MODEL=openai:gpt-4o
# AGENT_API_BASE=
# AGENT_API_KEY=
# AGENT_API_VERSION=

# Enable debug logging for agent execution
AGENT_DEBUG=false

# Authentication (via oauth2_lib) — set OAUTH2_ACTIVE=false to disable
OAUTH2_ACTIVE=false
# OIDC_BASE_URL=https://idp.example.com
# OIDC_CONF_URL=https://idp.example.com/.well-known/openid-configuration
# OAUTH2_RESOURCE_SERVER_ID=
# OAUTH2_RESOURCE_SERVER_SECRET=
# OAUTH2_TOKEN_URL=https://idp.example.com/oauth2/token
